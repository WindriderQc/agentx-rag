{
  "name": "agentx-rag",
  "version": "1.0.0",
  "description": "AgentX RAG — Document ingestion, embeddings, and semantic search",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "ingest:scan": "node ingestWorker.js --run",
    "test": "jest --forceExit --detectOpenHandles",
    "test:relevance": "jest --forceExit --detectOpenHandles --runTestsByPath tests/integration/relevance-golden.test.js"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^4.18.2",
    "mammoth": "^1.12.0",
    "mongoose": "^7.6.3",
    "node-fetch": "^2.7.0",
    "pdf-parse": "^2.4.5",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.2.2"
  }
}
