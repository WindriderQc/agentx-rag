<div class="container dashboard-container">
  <section class="dashboard-hero">
    <div class="dashboard-eyebrow">AgentX Retrieval Operations</div>
    <div class="dashboard-hero-row">
      <div>
        <h1 class="page-title dashboard-title">RAG Control Surface</h1>
        <p class="dashboard-subtitle">Live dependency health, active embedding route, and vector inventory for the retrieval stack now serving production queries.</p>
      </div>
      <div class="dashboard-sidecar">
        <div class="sidecar-label">Refresh Cadence</div>
        <div class="sidecar-value">30s live poll</div>
      </div>
    </div>
  </section>

  <div class="dashboard-grid">

    <!-- Service Health -->
    <section class="card health-card">
      <div class="card-title">Service Health</div>
      <div class="health-readout">
        <span id="service-dot" class="status-dot status-dot-lg"></span>
        <div>
          <div class="health-label">Runtime State</div>
          <div id="service-status" class="health-status loading">loading...</div>
        </div>
      </div>
      <p class="card-copy">This reflects process liveness and MongoDB connectivity. Vector store and embedding checks are shown separately so failures are easier to isolate.</p>
    </section>

    <!-- Dependency Health Matrix -->
    <section class="card dependency-card">
      <div class="card-title">Dependencies</div>
      <p class="card-copy dependency-copy">The embedding row now shows the actual configured model and proxy endpoint, so operators can confirm which retrieval path is active without opening the shell.</p>
      <table class="dep-table">
        <tbody>
          <tr id="dep-mongo">
            <td class="dep-name">MongoDB</td>
            <td class="dep-status"><span class="loading">loading...</span></td>
          </tr>
          <tr id="dep-qdrant">
            <td class="dep-name">Qdrant</td>
            <td class="dep-status"><span class="loading">loading...</span></td>
          </tr>
          <tr id="dep-embedding">
            <td class="dep-name">Embedding Provider</td>
            <td class="dep-status"><span class="loading">loading...</span></td>
          </tr>
        </tbody>
      </table>
    </section>

    <!-- Stats -->
    <section class="card stats-card">
      <div class="card-title">Collection Stats</div>
      <div class="stat-grid">
        <div class="stat-item">
          <div class="stat-value mono" id="stat-docs">--</div>
          <div class="stat-label">Documents</div>
        </div>
        <div class="stat-item">
          <div class="stat-value mono" id="stat-chunks">--</div>
          <div class="stat-label">Chunks</div>
        </div>
        <div class="stat-item">
          <div class="stat-value mono" id="stat-dimension">--</div>
          <div class="stat-label">Vector Dimension</div>
        </div>
      </div>
      <p class="card-copy stats-copy">A zero-document state is healthy right after a collection switch. The first ingest seeds the fresh Qdrant collection with the active vector dimension.</p>
    </section>

  </div>

  <!-- Footer -->
  <div class="footer dashboard-footer">
    Auto-refreshes every 30s &middot; Last updated: <span id="last-updated">--</span>
  </div>
</div>
